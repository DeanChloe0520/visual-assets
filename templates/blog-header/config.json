{
  "name": "blog-header",
  "version": "1.0.0",
  "description": "博客文章头部模板，包含标题、作者信息、元数据和特色图片",
  "author": "OpenClaw Visual System",
  "created": "2026-03-03",
  "category": "blog-content",
  "tags": ["blog", "header", "article", "publishing"],
  
  "variables": {
    "required": ["title", "author", "date"],
    "optional": {
      "theme": {
        "type": "string",
        "default": "default",
        "options": ["default", "professional", "creative", "minimal"],
        "description": "模板主题样式"
      },
      "category": {
        "type": "object",
        "properties": {
          "name": "string",
          "icon": "string"
        },
        "description": "文章分类信息"
      },
      "subtitle": {
        "type": "string",
        "description": "文章副标题"
      },
      "author": {
        "type": "object",
        "properties": {
          "name": "string",
          "avatar": "url",
          "initial": "string",
          "title": "string"
        },
        "description": "作者详细信息"
      },
      "readTime": {
        "type": "number",
        "description": "预计阅读时间（分钟）"
      },
      "wordCount": {
        "type": "number",
        "description": "文章字数"
      },
      "featuredImage": {
        "type": "object",
        "properties": {
          "url": "url",
          "alt": "string",
          "caption": "string"
        },
        "description": "特色图片信息"
      },
      "excerpt": {
        "type": "string",
        "default": "文章摘要内容...",
        "description": "文章摘要"
      },
      "tags": {
        "type": "array",
        "items": "string",
        "description": "文章标签数组"
      },
      "likes": {
        "type": "string|number",
        "default": "0",
        "description": "点赞数"
      },
      "commentsEnabled": {
        "type": "boolean",
        "default": true,
        "description": "是否启用评论"
      },
      "commentCount": {
        "type": "string|number",
        "default": "0",
        "description": "评论数"
      },
      "tableOfContents": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": "string",
            "title": "string"
          }
        },
        "description": "文章目录"
      },
      "series": {
        "type": "object",
        "properties": {
          "name": "string",
          "current": "number",
          "total": "number",
          "progress": "number"
        },
        "description": "系列文章信息"
      }
    }
  },
  
  "dimensions": {
    "default": {
      "width": 800,
      "height": "auto"
    },
    "featured": {
      "width": 1200,
      "height": 630,
      "aspectRatio": "1.91:1"
    },
    "social": {
      "width": 1200,
      "height": 628,
      "aspectRatio": "1.91:1"
    }
  },
  
  "dependencies": [
    "themes/default.json",
    "svg/icons/social/heart.svg",
    "svg/icons/social/comment.svg",
    "svg/icons/social/share.svg",
    "svg/icons/social/save.svg"
  ],
  
  "examples": [
    {
      "title": "GitHub存储方案：零成本视觉设计革命",
      "subtitle": "如何用GitHub仓库实现99.98%内存节省的视觉内容生成",
      "author": {
        "name": "技术探索者",
        "avatar": "https://example.com/avatar.jpg",
        "title": "高级工程师"
      },
      "date": "2026-03-03",
      "category": {
        "name": "技术教程",
        "icon": "💻"
      },
      "readTime": 8,
      "wordCount": 2500,
      "excerpt": "本文介绍了一种创新的视觉内容生成方案：使用GitHub作为CDN存储资源，实现零成本、极低内存占用的视觉设计系统。",
      "tags": ["GitHub", "CDN", "视觉设计", "性能优化", "零成本"],
      "likes": "1.5K",
      "commentCount": "89",
      "theme": "professional"
    },
    {
      "title": "创意写作的艺术与科学",
      "author": {
        "name": "文学爱好者",
        "initial": "✍️"
      },
      "date": "2026-03-03",
      "readTime": 12,
      "wordCount": 3500,
      "excerpt": "探索创意写作背后的心理学原理和实用技巧，帮助你在数字时代保持创作活力。",
      "tags": ["写作", "创意", "心理学", "文学"],
      "theme": "creative",
      "featuredImage": {
        "url": "https://example.com/creative-writing.jpg",
        "alt": "创意写作",
        "caption": "写作是思维的外化过程"
      }
    }
  ],
  
  "renderOptions": {
    "format": "html",
    "minify": true,
    "inlineStyles": true,
    "includeDoctype": true,
    "responsive": true,
    "darkModeSupport": true
  },
  
  "metadata": {
    "generator": "OpenClaw Visual Template System v1.0",
    "license": "MIT",
    "repository": "https://github.com/yourusername/visual-assets",
    "compatibility": ["social-card", "data-chart"]
  }
}